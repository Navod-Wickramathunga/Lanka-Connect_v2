# Copy this file to one of:
#   functions/.env.lankaconnect-app
#   functions/.env.new-lanka-connect-app
# Then fill values for that Firebase project before deploying functions.

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

PAYHERE_MERCHANT_ID=
PAYHERE_MERCHANT_SECRET=
PAYHERE_CHECKOUT_BASE_URL=

# Optional; defaults to https://<projectId>.firebaseapp.com when omitted.
PASSWORD_RESET_BASE_URL=
